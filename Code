utils.py

import re
def extract_data(text):
    data = {}
    invoice = re.search(r"Invoice\s*No[:\s]*(\w+)", text)
    date = re.search(r"Date[:\s]*([\d/.-]+)", text)
    amount = re.search(r"(Total|Amount)[:\s]*([\d,.]+)", text)
    data["invoice_number"] = invoice.group(1) if invoice else None
    data["date"] = date.group(1) if date else None
    data["amount"] = amount.group(2) if amount else None
    return data

